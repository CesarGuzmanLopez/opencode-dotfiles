{
  "$schema": "https://opencode.ai/config.json",

  // ── Sobre vision ──────────────────────────────────────────────────────
  // Todos los modelos tienen vision: true aunque el modelo físico no tenga
  // visión nativa. El proxy detecta imágenes en cualquier modelo y las
  // auto-describe (via Llama 4 Scout / MiMo Omni) ANTES de enviarlas al
  // LLM. El modelo nunca ve la imagen raw, solo la descripción textual.
  // Esto permite que cualquier pseudo-modelo "vea" imágenes indirectamente.
  //
  // ── Sobre tools ───────────────────────────────────────────────────────
  // tools/function_calling/parallel_tool_calls reflejan si el pseudo-modelo
  // DEBE recibir tool definitions. El compactador NO debe recibir tools
  // aunque Qwen3 32B las soporte — es un modelo interno de compactación,
  // no para uso interactivo con herramientas.
  // flash y vision NO soportan parallel_tool_calls porque sus primarios
  // (GPT-OSS 20B y Llama 4 Scout) no las soportan.
  //
  // ── Sobre reasoning ──────────────────────────────────────────────────
  // El nivel de razonamiento (thinking/reasoning_effort) se controla desde
  // el proxy vía default_thinking en pseudo_models.yaml. opencode no
  // necesita enviar thinking porque el proxy lo define por modelo.

  "default_agent": "plan",
  // Plugins auto-descubiertos desde plugins/*.ts — no listar aquí
  "plugin": [],
  "provider": {
    "guzman-lopez": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "guzman-lopez",
      "modalities": {
        "input": ["text", "image", "pdf"],
        "output": ["text"],
      },
      "options": {
        "baseURL": "https://chat.guzman-lopez.com/v1",
        "apiKey": "{API_KEY}",
      },
      "models": {
        // Razonamiento premium — tools completas, visión indirecta
        "pensamiento-profundo-caro": {
          "name": "Pensamiento Profundo",
          "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        // Desarrollo sostenido — tools completas
        "tareas-avanzadas": {
          "name": "Tareas Avanzadas",
          "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        // Punto de entrada recomendado — tools completas
        "normal": {
          "name": "Normal",
          "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        // Visión nativa + modelos de backup con auto-describe
        "vision": {
          "name": "Visión",
          "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": false,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        // Modelo gratuito / bajo costo
        "normal-gratis": {
          "name": "Normal Gratis",
          "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        // Sub-agentes rápidos — sin tools paralelas
        "flash": {
          "name": "Flash",
          "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": false,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
        // Compactador interno — NO usa tools ni function_calling
        // Aunque el modelo físico las soporte, este pseudo-modelo es solo
        // para compactación de contexto vía /compact. No recibe tools.
        "compactador": {
          "name": "Compactador",
          "capabilities": {
            "tools": false,
            "vision": true,
            "streaming": true,
            "function_calling": false,
            "parallel_tool_calls": false,
          },
          "modalities": {
            "input": ["text", "image", "pdf"],
            "output": ["text"],
          },
        },
      },
    },
  },

  // ── Agentes ──────────────────────────────────────────────────────────────
  "agent": {
    "plan": {
      "mode": "primary",
      "description": "Planning, analysis, and documentation research. Read-only.",
      "temperature": 0.1,
      "prompt": "You are a senior tech lead for planning and documentation research. Load the 'plan' skill for full protocol.",
      "permission": {
        "edit": "deny",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": {
          "plan": "allow",
          "read": "allow",
          "doc-scout": "allow",
          "fact-checker": "allow",
          "system-tools": "allow",
        },
        "question": "allow",
        "doom_loop": "allow",
      },
      "tools": {
        "context7_*": true,
        "web-search_*": true,
        "sequential-thinking": true,
        "sonarqube_*": true,
      },
    },
    "read": {
      "mode": "primary",
      "description": "Pure read-only mode. Minimal access.",
      "temperature": 0.1,
      "prompt": "You are a read-only assistant. Load the 'read' skill.",
      "permission": {
        "edit": "deny",
        "bash": "deny",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "deny",
        "external_directory": "allow",
        "todowrite": "deny",
        "webfetch": "deny",
        "websearch": "deny",
        "lsp": "allow",
        "skill": {
          "read": "allow",
          "plan": "allow",
          "system-tools": "allow",
        },
        "question": "allow",
        "doom_loop": "allow",
      },
      "tools": {
        "context7_*": true,
        "sequential-thinking": true,
        "sonarqube_*": true,
      },
    },

    "research": {
      "mode": "primary",
      "description": "All research: scientific, web, documentation, fact-checking. Creates comprehensive folders with PDFs, docs, and reports.",
      "temperature": 0.15,
      "prompt": "You are a research specialist. Load the 'deep-research' or 'scientific-research' skill based on the task. Create comprehensive research folders with PDFs, documentation, and detailed reports.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": {
          "deep-research": "allow",
          "scientific-research": "allow",
          "scientific-computing": "allow",
          "doc-scout": "allow",
          "fact-checker": "allow",
          "system-tools": "allow",
        },
        "question": "allow",
        "doom_loop": "ask",
      },
      "tools": {
        "arxiv_*": true,
        "pubchem_*": true,
        "pdf_*": true,
        "memory_*": true,
        "playwright_*": true,
        "web-search_*": true,
        "context7_*": true,
        "chart": true,
        "bat": true,
        "research-save": true,
        "save-findings": true,
        "load-findings": true,
        "sequential-thinking": true,
        "sonarqube_*": true,
      },
    },

    "coding": {
      "mode": "primary",
      "description": "Developer. Writes, debugs y refactoriza.",
      "temperature": 0.15,
      "prompt": "You are a Developer specialist. Load the coding skill.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": {
          "coding": "allow",
          "refactoring": "allow",
          "test-writer": "allow",
          "tdd": "allow",
          "commit-message": "allow",
          "systematic-debugging": "allow",
          "system-tools": "allow",
        },
        "question": "allow",
        "doom_loop": "ask",
      },
      "tools": {
        "ruff": true,
        "comby-search": true,
        "comby-replace": true,
        "git_*": true,
        "web-search_*": true,
        "context7_*": true,
        "verify-deps": true,
        "sequential-thinking": true,
        "sonarqube_*": true,
      },
    },
    "coding-web": {
      "mode": "primary",
      "description": "Web developer. Frontend, backend, APIs, y testing con Playwright.",
      "temperature": 0.15,
      "prompt": "You are a web development specialist. Load the coding skill.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": {
          "coding": "allow",
          "refactoring": "allow",
          "test-writer": "allow",
          "tdd": "allow",
          "commit-message": "allow",
          "systematic-debugging": "allow",
          "system-tools": "allow",
        },
        "question": "allow",
        "doom_loop": "ask",
      },
      "tools": {
        "playwright_*": true,
        "web-search_*": true,
        "context7_*": true,
        "comby-search": true,
        "comby-replace": true,
        "git_*": true,
        "verify-deps": true,
        "sequential-thinking": true,
        "sonarqube_*": true,
      },
    },
    "code-quality": {
      "mode": "primary",
      "description": "Code review, testing, and refactoring. Improves code quality.",
      "temperature": 0.15,
      "prompt": "You are a code quality specialist. Review code, write tests, and refactor for better quality. Load the appropriate skill for each task.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": {
          "code-reviewer": "allow",
          "test-writer": "allow",
          "tdd": "allow",
          "refactoring": "allow",
          "system-tools": "allow",
        },
        "question": "allow",
        "doom_loop": "ask",
      },
      "tools": {
        "git_*": true,
        "playwright_*": true,
        "comby-search": true,
        "comby-replace": true,
        "context7_*": true,
        "verify-deps": true,
        "save-findings": true,
        "load-findings": true,
        "sequential-thinking": true,
        "sonarqube_*": true,
      },
    },

    "build": {
      "mode": "primary",
      "temperature": 0.1,
      "description": "Handles project building and compilation tasks.",
      "prompt": "You are a build specialist. Execute build commands and manage project compilation.",
      "permission": {
        "edit": "allow",
        "bash": "allow",
        "read": "allow",
        "glob": "allow",
        "grep": "allow",
        "list": "allow",
        "task": "allow",
        "external_directory": "allow",
        "todowrite": "allow",
        "webfetch": "allow",
        "websearch": "allow",
        "lsp": "allow",
        "skill": {
          "coding": "allow",
          "refactoring": "allow",
          "test-writer": "allow",
          "tdd": "allow",
          "commit-message": "allow",
          "systematic-debugging": "allow",
          "system-tools": "allow",
        },
        "question": "allow",
        "doom_loop": "ask",
      },
      "tools": {
        // Built-in tools (whitelist explicito: el modelo no los alucina)
        "bash": true,
        "edit": true,
        "write": true,
        "read": true,
        "glob": true,
        "grep": true,
        "task": true,
        "todowrite": true,
        "webfetch": true,
        "websearch": true,
        "question": true,
        "skill": true,
        // Custom/MCP tools
        "verify-deps": true,
        "verify-opencode": true,
        "git_*": true,
        "arxiv_*": true,
        "pdf_*": true,
        "playwright_*": true,
        "memory_*": true,
        "pubchem_*": true,
        "web-search_*": true,
        "context7_*": true,
        "sequential-thinking": true,
        "sonarqube_*": true,
      },
    },
    // Compactador interno — usa el pseudo-modelo compactador (sin tools)
    "compaction": {
      "model": "guzman-lopez/compactador",
    },
  },
  "lsp": {
    "typescript": {
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/typescript-language-server",
        "--stdio",
      ],
      "extensions": [
        ".ts",
        ".tsx",
        ".js",
        ".jsx",
        ".mjs",
        ".cjs",
        ".mts",
        ".cts",
      ],
    },
    "python": {
      "command": ["pylsp"],
      "extensions": [".py", ".pyi"],
      "initialization": {
        "pylsp": {
          "plugins": {
            "preload": { "enabled": false },
            "pylint": { "enabled": false },
            "mypy_ls": { "enabled": false },
            "jedi_completion": { "resolve_at_most": 5 },
          },
        },
      },
    },
  },
  "mcp": {
    "playwright": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/playwright-mcp",
        "--browser",
        "chromium",
        "--executable-path",
        "/home/cesar/.cache/ms-playwright/chromium-1224/chrome-linux64/chrome",
        "--no-sandbox",
      ],
    },
    "sequential-thinking": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/mcp-server-sequential-thinking",
      ],
    },
    "memory": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/mcp-server-memory",
      ],
    },
    // Context7 — Documentación versionada de librerías (previene alucinaciones de APIs)
    "context7": {
      "type": "local",
      "enabled": true,
      "command": [
        "npx",
        "-y",
        "@upstash/context7-mcp",
      ],
    },
    // Búsqueda web multi-motor (Bing/Brave/DuckDuckGo) + extracción de contenido
    // Reemplaza: fetch + duckduckgo
    "web-search": {
      "type": "local",
      "enabled": true,
      "command": [
        "node",
        "/home/cesar/.config/opencode/mcp-servers/web-search-mcp/dist/index.js",
      ],
      "env": {
        "BROWSER_HEADLESS": "true",
        "MAX_BROWSERS": "2",
        "DEFAULT_TIMEOUT": "8000",
      },
    },

    // ArXiv papers — versión Python (blazickjp/arxiv-mcp-server)
    // Reemplaza: arxiv npm (más features: download, read, semantic search)
    "arxiv": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.local/bin/arxiv-mcp-server",
        "--storage-path",
        "/home/cesar/.arxiv-mcp-server/papers",
      ],
    },
    "pdf": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/pdf-reader-mcp",
      ],
    },
    "git": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/git-mcp-server",
      ],
    },
    "pubchem": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/pubchem-mcp-server",
      ],
    },
    "sonarqube": {
      "type": "local",
      "enabled": true,
      "command": [
        "/home/cesar/.config/opencode/node_modules/.bin/sonarqube-mcp",
      ],
      "environment": {
        "SONAR_HOST_URL": "http://localhost:9000",
        "SONAR_TOKEN": "{SONAR_TOKEN}",
      },
     },
   },
   "permission": {
       "ruff": "allow",
       "verify-deps": "allow",
       "verify-opencode": "allow",
       "web-search_*": "allow",
       "arxiv_*": "allow",
       "git_*": "allow",
       "pdf_*": "allow",
       "playwright_*": "allow",
       "memory_*": "allow",
       "pubchem_*": "allow",
       "context7_*": "allow",
       "sequential-thinking": "allow",
       "sonarqube": "allow",
     "skill": {
       "build": "deny",
       "plan": "deny",
       "read": "deny",
       "yolo": "deny",
       "coding": "deny",
       "scientific-research": "deny",
       "scientific-computing": "deny",
       "deep-research": "deny",
       "doc-scout": "deny",
       "fact-checker": "deny",
       "code-reviewer": "deny",
       "refactoring": "deny",
       "test-writer": "deny",
       "tdd": "deny",
       "commit-message": "deny",
       "systematic-debugging": "deny",
     },
  },
  "tools": {
    "git_*": true,
    "arxiv_*": true,
    "pdf_*": true,

    "playwright_*": true,
    "memory_*": true,
    "pubchem_*": true,
    "web-search_*": true,
    "context7_*": true,
    "sequential-thinking": true,
    "sonarqube": true,
  },
}
