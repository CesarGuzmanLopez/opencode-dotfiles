              "text"
            ]
          }
        },
    "normal-gratis": {
      "name": "Normal Gratis",
      "limit": { "context": 500000, "output": 16384 },
      "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          },
          "modalities": {
            "input": [
              "text",
              "image",
