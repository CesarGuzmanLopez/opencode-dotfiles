{
  "$schema": "https://opencode.ai/config.json",
  "default_agent": "plan",
  "model": "guzman-lopez/normal-gratis",
  "autoupdate": "notify",
  "plugin": [],
  "compaction": {
    "auto": true,
    "prune": true,
    "keep": { "tokens": 2000 },
    "buffer": 10000
  },
  "provider": {
    "guzman-lopez": {
      "npm": "@ai-sdk/openai-compatible",
      "name": "guzman-lopez",
      "modalities": {
        "input": [
          "text",
          "image",
          "pdf"
        ],
        "output": [
          "text"
        ]
      },
      "options": {
        "baseURL": "https://llm.guzman-lopez.com/v1",
        "apiKey": "26Ts_4ggCtJr9kSkppMZge-LQGYryTkDIK6mM-O2hOI"
      },
      "models": {
    "pensamiento-profundo-caro": {
      "name": "Pensamiento Profundo",
      "limit": { "context": 235930, "output": 65536 },
      "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
    "tareas-avanzadas": {
      "name": "Tareas Avanzadas",
      "limit": { "context": 900000, "output": 65536 },
      "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          },
          "modalities": {
            "input": [
              "text",
              "image",
              "pdf"
            ],
            "output": [
              "text"
            ]
          }
        },
    "normal": {
      "name": "Normal",
      "limit": { "context": 900000, "output": 32768 },
      "capabilities": {
            "tools": true,
            "vision": true,
            "streaming": true,
            "function_calling": true,
            "parallel_tool_calls": true
          },
          "modalities": {
            "input": [
              "text",
