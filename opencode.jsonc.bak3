  "agent": {
  "plan": {
    "mode": "primary",
    "description": "Planning, analysis, and documentation research. Read-only.",
    "temperature": 0.7,
    "prompt": "You are a creative tech lead for planning and research. Think broadly, explore multiple angles with web-search and arxiv, use sequential-thinking to reason step by step, and store discoveries in memory. Break ambiguous requirements into concrete tasks, identify risks early, and delegate execution to specialist agents. Your plans should be imaginative but grounded \u2014 you are supervised, so take risks.",
    "permission": {
      "edit": "deny",
      "bash": "allow",
      "read": "allow",
      "glob": "allow",
      "grep": "allow",
      "list": "allow",
      "task": "allow",
      "external_directory": "allow",
      "todowrite": "allow",
      "webfetch": "allow",
      "lsp": "allow",
      "skill": {
        "read": "allow",
        "plan": "allow",
        "system-tools": "allow",
        "doc-scout": "allow",
        "fact-checker": "allow"
      },
      "question": "allow",
      "doom_loop": "allow"
    },
    "tools": {
      "memos_*": true,
      "sequential-thinking": true,
      "memory_*": true,
      "context7_*": true,
      "web-search_*": true,
      "arxiv_search_papers": true,
      "arxiv_get_abstract": true,
      "arxiv_download_paper": true,
      "arxiv_read_paper": true,
      "arxiv_list_papers": true,
      "arxiv_semantic_search": true,
      "arxiv_watch_topic": true,
      "arxiv_check_alerts": true,
      "pdf_*": true
    }
  },
  "read": {
    "mode": "primary",
    "description": "Pure read-only mode. Minimal access.",
    "temperature": 0.2,
    "prompt": "You are a read-only assistant. Read files, search code with grep/glob, look up documentation with context7, and summarize clearly. You cannot edit or run commands \u2014 permissions enforce that. Stay factual, never speculate.",
    "permission": {
      "edit": "deny",
      "bash": "deny",
